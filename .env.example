# Copy this file to .env.local and fill in real values.
# Never commit real keys. Set the same vars in Vercel → Project → Settings → Environment Variables.
# Do not use the service_role key in the frontend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: restrict /admin to a single account (must match the user email in Supabase Auth).
# VITE_ADMIN_EMAIL=you@yourdomain.com
